{
  "name": "color-palette-pro",
  "version": "1.0.0",
  "description": "Powerful, mathematical color palette generation logic using OKLCH and colorjs.io",
  "author": "",
  "license": "MIT",
  "keywords": ["color", "palette", "generator", "oklch", "colors", "design-system"],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "colorjs.io": "^0.5.2"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
